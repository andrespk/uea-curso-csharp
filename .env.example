# Docker Compose - Environment Variables Example

# PostgreSQL
POSTGRES_DB=minikanban
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# .NET API
ASPNETCORE_ENVIRONMENT=Production
ConnectionString=Host=minikanban-db;Port=5432;Database=minikanban;Username=postgres;Password=postgres;
Jwt__Key=MiniKanbanSuperSecretKeyFor2026PleaseChangeThis123456789!@#$%^&*()
Jwt__Issuer=https://minikanban.local
Jwt__Audience=https://minikanban.local

# Frontend (Vite)
VITE_API_URL=http://localhost:5093

